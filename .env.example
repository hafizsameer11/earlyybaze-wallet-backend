APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Tatum — wallet provisioning, webhooks, on-chain tx verification
TATUM_API_KEY=
TATUM_BASE_URL=https://api.tatum.io/v3
TATUM_V4_BASE_URL=https://api.tatum.io/v4
# Optional: override v4 webhook URL (defaults in config/tatum.php webhook_v2_url)
# TATUM_WEBHOOK_V2_URL="${APP_URL}/api/webhook/v2"
TATUM_V4_NETWORK_TYPE=mainnet

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Ops email recipients for manual flush + AI audit notifications
AUTO_FLUSH_EMAILS=

# AI audit (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Sent.dm — v3 WhatsApp phone verification (https://www.sent.dm/)
SENT_DM_API_KEY=
# Optional: Sent includes 6 pre-built OTP templates after email+phone verify.
# Leave blank to auto-pick an OTP template via GET /v3/templates.
SENT_DM_WHATSAPP_TEMPLATE_ID=
# Optional: match a pre-built template by name substring (e.g. otp)
# SENT_DM_TEMPLATE_NAME=otp
# Template variable for the OTP code (Sent pre-built template uses var_1)
SENT_DM_OTP_PARAMETER=var_1
# Comma-separated channels: whatsapp, sms, rcs (sms,whatsapp recommended for fallback)
SENT_DM_CHANNELS=sms,whatsapp
SENT_DM_SANDBOX=false
# SENT_DM_BASE_URL=https://api.sent.dm
# Webhook — register {APP_URL}/api/webhook/sent in Sent Dashboard (message events)
# Copy signing secret from Sent Dashboard → Webhooks → your endpoint → eye icon
SENT_DM_WEBHOOK_SECRET=
# SENT_DM_WEBHOOK_TIMESTAMP_TOLERANCE=300
